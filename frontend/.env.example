# Desarrollo con backend Java (puerto 8081). No hace falta definir nada
# porque el frontend por defecto usa: http://localhost:8081/api/v1
# VITE_API_BASE=http://localhost:8081/api/v1

# Producción (Render): URL pública del backend
# VITE_API_BASE=https://TU-BACKEND.onrender.com/api/v1

# Alternativa: si sirves frontend+backend bajo el mismo dominio/ruta
# VITE_API_BASE=/api/v1
