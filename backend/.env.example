## PostgreSQL local (por defecto en application.yml)
# DATABASE_URL=jdbc:postgresql://localhost:5432/entrelazados_asistencia
# DB_USER=postgres
# DB_PASSWORD=postgres

## JWT (en producción CAMBIAR el secret)
# APP_JWT_SECRET=entrelazados2026SecretKeyForJWTSigningMustBe64CharsLongForHS256Algorithm!
# APP_JWT_EXPIRATIONMS=86400000

## CORS (separado por comas)
# APP_CORS_ALLOWEDORIGINS=http://localhost:5173,http://localhost:5174

## Cierre automatico de asistencia (19:00)
# APP_ATTENDANCE_AUTOCHECKOUT_ENABLED=true
# APP_ATTENDANCE_AUTOCHECKOUT_CRON=0 0 19 * * *
# APP_ATTENDANCE_AUTOCHECKOUT_ZONE=America/Bogota

